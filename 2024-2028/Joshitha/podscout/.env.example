# Application
APP_NAME=PodScout Pro
APP_VERSION=0.1.0
DEBUG=True

# Supabase (Database - REQUIRED)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# LLM APIs (REQUIRED for AI features)
GROQ_API_KEY=your-groq-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# Pinecone (Optional - for vector search)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENV=us-east-1
PINECONE_INDEX_NAME=podscout-embeddings

# Redis (for caching - RECOMMENDED)
# For local Redis: redis://localhost:6379/0
# For Redis Labs: redis://default:YOUR_PASSWORD@hostname:port/0
REDIS_URL=redis://default:your-password@redis-15040.c15.us-east-1-4.ec2.cloud.redislabs.com:15040/0

# Google Earth Engine (OPTIONAL - for satellite data)
GEE_SERVICE_ACCOUNT=your-service-account@project.iam.gserviceaccount.com
GEE_PRIVATE_KEY_PATH=/path/to/service-account-key.json

# Google OAuth (for authentication/authorization)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Auth Settings
AUTH_REDIRECT_URL=http://localhost:8501

# External APIs (OPTIONAL - for real sensor data)
CPCB_API_KEY=your-cpcb-api-key-if-available
OPENAQ_API_KEY=your-openaq-api-key-optional

# Spatial Configuration
DEFAULT_GRID_SIZE_METERS=500
