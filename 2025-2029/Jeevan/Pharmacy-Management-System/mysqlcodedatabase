CREATE TABLE medicines (
    id INT AUTO_INCREMENT PRIMARY KEY,
    name VARCHAR(100) UNIQUE,
    category VARCHAR(50),
    manufacturer VARCHAR(100),
    price DECIMAL(10,2) NOT NULL,
    expiry_date DATE,
    stock INT NOT NULL DEFAULT 0
);

