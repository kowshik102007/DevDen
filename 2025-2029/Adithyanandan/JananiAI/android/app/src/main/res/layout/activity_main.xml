<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F5F5">

    <TextView
        android:id="@+id/app_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="जननी AI"
        android:textSize="28sp"
        android:textColor="#0B6E6E"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingTop="16dp"
        android:paddingBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Har maa surakshit ho"
        android:textSize="14sp"
        android:textColor="#666666"
        android:gravity="center"
        android:paddingBottom="16dp" />

    <Button
        android:id="@+id/btn_add_patient"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="+ New Patient Registration"
        android:backgroundTint="#0B6E6E"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Registered Patients"
        android:textSize="18sp"
        android:textColor="#333333"
        android:textStyle="bold"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/empty_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No patients registered yet"
        android:textSize="16sp"
        android:textColor="#999999"
        android:gravity="center"
        android:paddingTop="32dp"
        android:visibility="gone" />

    <ListView
        android:id="@+id/patient_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:divider="#E0E0E0"
        android:dividerHeight="1dp" />

</LinearLayout>