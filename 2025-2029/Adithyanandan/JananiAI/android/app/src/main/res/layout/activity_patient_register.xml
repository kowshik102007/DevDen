<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Patient Registration"
            android:textSize="22sp"
            android:textColor="#0B6E6E"
            android:textStyle="bold"
            android:paddingBottom="16dp" />

        <EditText
            android:id="@+id/input_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Name *"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/input_age"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Age"
            android:inputType="number"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/input_village"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Village"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/input_asha_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="ASHA Worker ID"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/input_lmp_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Last Menstrual Period (YYYY-MM-DD)"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/input_gravida"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Gravida (number of pregnancies)"
            android:inputType="number"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/input_parity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Parity (previous births)"
            android:inputType="number"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/input_prev_complications"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Previous Complications (0=None, 1=One, 2=Multiple)"
            android:inputType="number"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Patient"
            android:backgroundTint="#0B6E6E"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btn_cancel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:backgroundTint="#999999"
            android:textColor="#FFFFFF"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>