<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/card_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:id="@+id/risk_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingTop="48dp"
        android:paddingBottom="16dp" />

    <TextView
        android:id="@+id/risk_level"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="36sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="32dp" />

    <TextView
        android:id="@+id/reasons_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:gravity="left"
        android:lineSpacingExtra="8dp"
        android:paddingHorizontal="16dp"
        android:paddingBottom="32dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <Button
            android:id="@+id/btn_ambulance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📞 108 Ambulance"
            android:backgroundTint="#FFFFFF"
            android:textColor="#C62828"
            android:textSize="18sp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_anm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📱 ANM Ko Batayein"
            android:backgroundTint="#FFFFFF"
            android:textColor="#333333"
            android:textSize="18sp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_phc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🏥 PHC Directions"
            android:backgroundTint="#FFFFFF"
            android:textColor="#333333"
            android:textSize="18sp"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btn_close"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Close"
            android:backgroundTint="#333333"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />
    </LinearLayout>

</LinearLayout>