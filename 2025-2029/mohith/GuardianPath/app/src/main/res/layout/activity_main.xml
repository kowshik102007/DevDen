<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/backgroundColor"
    tools:context=".MainActivity">

    <!-- Top Premium Header Background -->
    <View
        android:id="@+id/headerBackground"
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:background="@color/primaryColor"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- App Identity -->
    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="56dp"
        android:layout_marginStart="24dp"
        android:src="@drawable/ic_launcher_foreground"
        app:tint="@color/colorOnPrimary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <ImageView
        android:id="@+id/btnSettings"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="56dp"
        android:layout_marginEnd="24dp"
        android:padding="12dp"
        android:src="@drawable/ic_settings"
        app:tint="@color/colorOnPrimary"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Guardian Path"
        android:textColor="@color/colorOnPrimary"
        android:textSize="32sp"
        android:textStyle="bold"
        android:letterSpacing="-0.01"
        android:layout_marginTop="16dp"
        android:layout_marginStart="24dp"
        app:layout_constraintTop_toBottomOf="@id/ivLogo"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Stay connected, stay secure."
        android:textColor="@color/subtitleColor"
        android:textSize="16sp"
        android:layout_marginTop="4dp"
        android:layout_marginStart="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Action Cards Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:clipToPadding="false"
        android:paddingBottom="24dp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Start Journey Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardStart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:strokeWidth="0dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical"
                android:background="@color/surfaceColor">

                <!-- Icon Container -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    app:cardCornerRadius="28dp"
                    app:cardBackgroundColor="@color/bg_success"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    android:layout_marginEnd="16dp">
                    
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_play"
                        app:tint="@color/green_success"
                        android:layout_gravity="center"/>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Start Journey"
                        android:textColor="@color/green_success"
                        android:textSize="18sp"
                        android:textStyle="bold"/>
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Share real-time location"
                        android:textColor="@color/textColorSecondary"
                        android:textSize="14sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_play"
                    app:tint="@color/iconTint"
                    android:rotation="180"/> <!-- A simple arrow placeholder -->
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Report Area Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardReport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:strokeWidth="0dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical"
                android:background="@color/surfaceColor">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    app:cardCornerRadius="28dp"
                    app:cardBackgroundColor="@color/bg_warning"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    android:layout_marginEnd="16dp">
                    
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_warning"
                        app:tint="@color/orange_warning"
                        android:layout_gravity="center"/>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Report Area"
                        android:textColor="@color/orange_warning"
                        android:textSize="18sp"
                        android:textStyle="bold"/>
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mark an unsafe location"
                        android:textColor="@color/textColorSecondary"
                        android:textSize="14sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Emergency Button - Very Prominent -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/> <!-- Spacer -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEmergency"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:text="EMERGENCY SOS"
            app:icon="@drawable/ic_emergency"
            app:iconGravity="textStart"
            app:iconSize="28dp"
            app:iconPadding="12dp"
            android:textSize="20sp"
            android:textStyle="bold"
            app:cornerRadius="36dp"
            app:backgroundTint="@color/red_error"
            android:textColor="@color/colorOnPrimary"
            app:elevation="8dp"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
